# colcon build artifacts - match at ANY depth, not just top-level ros2_ws/
**/build/
**/install/
**/log/

# Gazebo's full stock model library - regenerated by setup_gazebo_worlds.sh
# / fetched fresh via gz fuel download (see Dockerfile)
**/simulation_models/temp_models/

# Pretrained model weights - re-downloadable (see README)
*.pt

# Rosbag recordings - record fresh as needed during development,
# don't accumulate test recordings in git history. Promote a real
# evaluation run to git (or Git LFS / external storage) deliberately,
# not by default.
*.mcap
*.db3
*.bag

# Debug / generated artifacts from past debugging sessions
build_error.txt
frames_*.gv
frames_*.pdf

# Python
__pycache__/
*.pyc
*.egg-info/

# Gazebo runtime cache (bind-mounted from host, not part of repo)
.gz/

# IDE / OS
.vscode/
.DS_Store
*.swp
output.log
ros2_ws/.claude/
ros2_ws/CLAUDE.md
ros2_ws/debug_notes_2026-06-24.md
